{
  "name": "@my-resume/ui",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/theme.tsx",
      "import": "./dist/theme.js",
      "default": "./dist/theme.js"
    },
    "./theme": {
      "types": "./src/theme.tsx",
      "import": "./dist/theme.js",
      "default": "./dist/theme.js"
    },
    "./display": {
      "types": "./src/display.tsx",
      "import": "./dist/display.js",
      "default": "./dist/display.js"
    },
    "./display.css": "./src/display.css",
    "./heroui-base.css": "./src/heroui-base.css",
    "./heroui-web.css": "./src/heroui-web.css",
    "./heroui-admin.css": "./src/heroui-admin.css"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "lint": "oxlint --config ../../.oxlintrc.json --ignore-path ../../.eslintignore .",
    "format:check": "oxfmt --config ../../.oxfmtrc.json --ignore-path ../../.prettierignore --check .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "jsdom": "^26.1.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
