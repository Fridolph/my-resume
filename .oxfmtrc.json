{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": false,
  "singleQuote": true,
  "trailingComma": "all",
  "printWidth": 90,
  "useTabs": false,
  "tabWidth": 2,
  "endOfLine": "lf",
  "vueIndentScriptAndStyle": false,
  "bracketSpacing": true,
  "bracketSameLine": true,
  "jsxSingleQuote": false,
  "proseWrap": "preserve",
  "htmlWhitespaceSensitivity": "css",
  "insertFinalNewline": true,
  "sortImports": false,
  "sortPackageJson": false,
  "sortTailwindcss": false,
  "jsdoc": false,
  "ignorePatterns": [
    ".git/**",
    ".next/**",
    ".pnpm-store/**",
    ".turbo/**",
    ".data/**",
    "apps/.data/**",
    "coverage/**",
    "dist/**",
    "node_modules/**",
    "tmp/**",
    "docs/**",
    "blog/**",
    "public/**/*.pdf",
    "public/**/*.png",
    "public/**/*.jpg",
    "public/**/*.jpeg",
    "public/**/*.webp",
    "public/**/*.ico",
    "tailwind.config.cjs",
    "postcss.config.cjs",
    "src/assets/iconfont/**"
  ]
}
