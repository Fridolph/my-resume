NODE_ENV=development

# 服务监听配置
PORT=5577
API_HOST=0.0.0.0

# 允许跨域的前端来源，多个地址用英文逗号分隔
CORS_ORIGINS=http://localhost:5555,http://127.0.0.1:5555,http://localhost:5566,http://127.0.0.1:5566

# 前端访问后端的公开地址
NEXT_PUBLIC_API_BASE_URL=http://localhost:5577

# web 在服务端渲染时优先使用的后端地址
# 本地开发保持 localhost 即可；docker compose 会覆盖成 http://server:5577
RESUME_API_BASE_URL=http://localhost:5577

# PDF 导出中文字体（可选，未设置时会按系统候选路径自动探测）
# PDF_CJK_FONT_PATH=/usr/share/fonts/opentype/noto/NotoSansCJK-Regular.ttc

# 数据库
DATABASE_URL=file:./.data/my-resume.db
# DATABASE_AUTH_TOKEN=replace-with-your-own-token

# 鉴权
JWT_SECRET=replace-with-your-own-secret
# 是否在服务启动时自动补齐默认 admin/viewer 账号（默认 true）
AUTH_BOOTSTRAP_DEFAULT_USERS=true
# 默认账号（可按需覆盖）
AUTH_ADMIN_USERNAME=admin
AUTH_VIEWER_USERNAME=viewer
# 默认密码（生产环境务必改成高强度密码）
AUTH_ADMIN_PASSWORD=admin123456
AUTH_VIEWER_PASSWORD=viewer123456

# AI Provider 配置示例
# mock / qiniu / deepseek / openai-compatible
AI_PROVIDER=qiniu

# 七牛云（OpenAI-compatible）
QINIU_AI_API_KEY=replace-with-your-own-key
QINIU_AI_BASE_URL=https://api.qnaigc.com/v1
QINIU_AI_MODEL=deepseek-v3

# DeepSeek（OpenAI-compatible）
# DEEPSEEK_API_KEY=replace-with-your-own-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat

# 其他 OpenAI-compatible Provider
# OPENAI_COMPATIBLE_API_KEY=replace-with-your-own-key
# OPENAI_COMPATIBLE_BASE_URL=https://your-provider.example.com/v1
# OPENAI_COMPATIBLE_MODEL=your-model
