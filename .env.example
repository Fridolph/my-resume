NUXT_PUBLIC_SITE_URL=https://fridolph.com
NUXT_PUBLIC_SITE_NAME=Fridolph Web
NUXT_PUBLIC_SITE_DESCRIPTION=个人内容展示站，承载主页、简历、项目与多语言内容。
NUXT_PUBLIC_DEFAULT_LOCALE=zh-CN

# Admin App (apps/admin)
NUXT_PUBLIC_ADMIN_API_BASE_URL=http://localhost:3011/api/admin
