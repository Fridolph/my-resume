NODE_ENV=development

# 服务监听配置
PORT=5577
API_HOST=0.0.0.0

# 允许跨域的前端来源，多个地址用英文逗号分隔
CORS_ORIGINS=http://localhost:5555,http://127.0.0.1:5555,http://localhost:5566,http://127.0.0.1:5566

# 前端访问后端的公开地址
NEXT_PUBLIC_API_BASE_URL=http://localhost:5577

# web 在服务端渲染时优先使用的后端地址
# 本地开发保持 localhost 即可；docker compose 会覆盖成 http://server:5577
RESUME_API_BASE_URL=http://localhost:5577

# PDF 导出中文字体（可选，未设置时会按系统候选路径自动探测）
# PDF_CJK_FONT_PATH=/usr/share/fonts/opentype/noto/NotoSansCJK-Regular.ttc

# 数据库
DATABASE_URL=file:./.data/my-resume.db
# DATABASE_AUTH_TOKEN=replace-with-your-own-token

# 鉴权
JWT_SECRET=replace-with-your-own-secret
# 是否在服务启动时自动补齐默认 admin/viewer 账号（默认 true）
AUTH_BOOTSTRAP_DEFAULT_USERS=true
# 默认账号（可按需覆盖）
AUTH_ADMIN_USERNAME=admin
AUTH_VIEWER_USERNAME=viewer
# 默认密码（生产环境务必改成高强度密码）
AUTH_ADMIN_PASSWORD=admin123456
AUTH_VIEWER_PASSWORD=viewer123456

# AI Provider 配置示例
# mock / qiniu / deepseek / openai-compatible
AI_PROVIDER=deepseek

# 七牛云（OpenAI-compatible）
# QINIU_AI_API_KEY=replace-with-your-own-key
# QINIU_AI_BASE_URL=https://api.qnaigc.com/v1
# QINIU_AI_MODEL=deepseek-v3

# DeepSeek（OpenAI-compatible）
DEEPSEEK_API_KEY=replace-with-your-own-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL_NAME=deepseek-v4-flash
# DEEPSEEK_MODEL=deepseek-v4-flash
# DEEPSEEK_THINKING_ENABLED=false
# DEEPSEEK_REASONING_EFFORT=high
# DEEPSEEK_MAX_TOKENS=8192
# DeepSeek 官方 API 不提供 embeddings；默认向量能力走 Qwen / DashScope 兼容接口。
EMBEDDINGS_API_KEY=replace-with-your-own-key
# EMBEDDINGS_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# EMBEDDINGS_MODEL_NAME=text-embedding-v3
# Milvus 向量存储默认关闭；仅在本地实验向量检索时按需开启
# RAG_VECTOR_STORE_BACKEND=milvus
# RAG_MILVUS_MODE=sdk
# RAG_MILVUS_ADDRESS=http://127.0.0.1:19530
# RAG_MILVUS_COLLECTION=resume_rag_chunks
# RAG_MILVUS_VECTOR_DIMENSION=1536
# RAG_SEARCH_USE_VECTOR_STORE=true
# RAG_SEARCH_VECTOR_SCOPE=all
# RAG_SEARCH_VECTOR_FALLBACK_TO_LOCAL=true
# RAG 检索质量门控：最低分阈值（0~1），低于此分的结果会被过滤
# RAG_SEARCH_MIN_SCORE=0.1
# RAG 检索质量门控：前两名最小分差，超过此差值时只保留第一名
# RAG_SEARCH_MIN_SCORE_GAP=0.15
# AI Chat RAG 回答最低匹配分阈值：最高 citation 分低于该值时直接拒答，不调用 LLM（默认 0.05）
# RAG_CHAT_MIN_SCORE=0.05
# 简历导入 AI 诊断日志：默认写入 logs/ai-server，生产环境默认不记录完整模型原文。
# AI_RESUME_IMPORT_LOG_RAW=false
# AI_RESUME_IMPORT_LOG_DIR=logs/ai-server

# 其他 OpenAI-compatible Provider
# OPENAI_COMPATIBLE_API_KEY=replace-with-your-own-key
# OPENAI_COMPATIBLE_BASE_URL=https://your-provider.example.com/v1
# OPENAI_COMPATIBLE_MODEL=your-model
