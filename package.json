{
  "name": "my-resume-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.8.0",
  "scripts": {
    "dev": "pnpm dev:all",
    "dev:all": "pnpm build:shared && turbo run dev --filter=@my-resume/server --filter=@my-resume/web --filter=@my-resume/admin --parallel",
    "dev:server": "pnpm --filter @my-resume/server dev",
    "dev:web": "pnpm build:shared && pnpm --filter @my-resume/web dev",
    "dev:admin": "pnpm build:shared && pnpm --filter @my-resume/admin dev",
    "dev:shared": "turbo run dev --filter=@my-resume/api-client --filter=@my-resume/ui --filter=@my-resume/utils --parallel",
    "start": "pnpm start:all",
    "start:all": "pnpm --parallel --filter @my-resume/server --filter @my-resume/web --filter @my-resume/admin run start",
    "start:server": "pnpm --filter @my-resume/server start",
    "start:web": "pnpm --filter @my-resume/web start",
    "start:admin": "pnpm --filter @my-resume/admin start",
    "build": "pnpm build:all",
    "build:shared": "pnpm --filter @my-resume/utils build && pnpm --filter @my-resume/api-client build && pnpm --filter @my-resume/ui build",
    "lint": "pnpm lint:ox && pnpm lint:eslint:server",
    "lint:ox": "oxlint --config .oxlintrc.json --ignore-path .eslintignore .",
    "lint:eslint:server": "pnpm --filter @my-resume/server lint:eslint",
    "format": "oxfmt --config .oxfmtrc.json --ignore-path .prettierignore .",
    "format:check": "oxfmt --config .oxfmtrc.json --ignore-path .prettierignore --check .",
    "typecheck": "pnpm typecheck:all",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "test": "turbo run test",
    "test:unit": "pnpm build:shared && turbo run test --filter=@my-resume/server --filter=@my-resume/web --filter=@my-resume/admin --filter=@my-resume/api-client --filter=@my-resume/ui",
    "test:e2e": "pnpm --filter @my-resume/server test:e2e",
    "test:ci": "pnpm test:unit && pnpm test:e2e",
    "typecheck:all": "turbo run typecheck",
    "build:all": "turbo run build",
    "check:tsx-types": "node scripts/check-tsx-types.mjs",
    "test:workspace": "node scripts/check-workspace.mjs && pnpm check:tsx-types",
    "perf:dev:web": "node scripts/perf-dev-route.mjs --target web --base-url http://127.0.0.1:5555 --routes /zh,/zh/profile --output .tmp/perf/dev-web.json",
    "perf:dev:admin": "node scripts/perf-dev-route.mjs --target admin --base-url http://127.0.0.1:5566 --routes /zh/dashboard,/zh/dashboard/resume,/zh/dashboard/ai,/zh/dashboard/publish --output .tmp/perf/dev-admin.json",
    "perf:build:analyze": "pnpm build:shared && pnpm --filter @my-resume/web build && pnpm --filter @my-resume/admin build && node scripts/perf-build-analyze.mjs --apps web,admin --output .tmp/perf/build-report.json"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.11.8",
    "eslint-plugin-oxlint": "^1.59.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "turbo": "^2.8.20",
    "typescript": "5.4.5"
  }
}
