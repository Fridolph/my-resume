# Git 仓库来源
REPO_URL=https://github.com/your-name/my-resume.git

# 部署根目录（默认 /opt/my-resume，如需修改可取消注释）
# DEPLOY_ROOT=/opt/my-resume

# 主域名 / 子域名
ROOT_DOMAIN=example.com
RESUME_DOMAIN=resume.example.com
ADMIN_DOMAIN=admin-resume.example.com
API_DOMAIN=api-resume.example.com

# Let's Encrypt
LETSENCRYPT_EMAIL=ops@example.com

# 鉴权
JWT_SECRET=replace-with-a-long-random-secret

# 证书名称（默认等于 RESUME_DOMAIN，可按需覆盖）
# CERTBOT_CERT_NAME=resume.example.com
# 证书密钥类型（已有 ECDSA 证书时保持 ecdsa，避免 Certbot 误判为切换 RSA）
CERTBOT_KEY_TYPE=ecdsa
# ACME challenge webroot。不要放在 /root 下，否则 nginx 用户可能无法读取。
CERTBOT_WEBROOT=/var/www/my-resume-certbot

# AI Provider
AI_PROVIDER=qiniu
QINIU_AI_API_KEY=replace-with-your-own-key
QINIU_AI_BASE_URL=https://api.qnaigc.com/v1
QINIU_AI_MODEL=deepseek-v3
# QINIU_AI_CHAT_MODEL=deepseek-v3
# QINIU_AI_EMBEDDING_MODEL=text-embedding-v4

# 其他 Provider 预留（按需填写）
# DEEPSEEK_API_KEY=replace-with-your-own-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat
# OPENAI_COMPATIBLE_API_KEY=replace-with-your-own-key
# OPENAI_COMPATIBLE_BASE_URL=https://your-provider.example.com/v1
# OPENAI_COMPATIBLE_MODEL=your-model
