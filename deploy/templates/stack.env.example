# Git 仓库来源
REPO_URL=https://github.com/your-name/my-resume.git

# 部署根目录（默认 /opt/my-resume，如需修改可取消注释）
# DEPLOY_ROOT=/opt/my-resume

# 部署模式：
# - build: ECS 上执行 docker compose --build（默认）
# - image: ECS 只拉镜像并启动（推荐 2核2G 机器）
DEPLOY_MODE=image
# 可选：固定 compose project 名，避免每次发布目录变化导致旧容器残留占用端口
# DEPLOY_COMPOSE_PROJECT_NAME=my-resume

# image 模式镜像配置（二选一）
# 方案 A：填前缀，自动推导 server/web/admin 三个仓库
IMAGE_REPOSITORY_PREFIX=ghcr.io/your-name/my-resume
# 方案 B：显式指定每个服务镜像仓库（覆盖前缀推导）
# SERVER_IMAGE=ghcr.io/your-name/my-resume/server
# WEB_IMAGE=ghcr.io/your-name/my-resume/web
# ADMIN_IMAGE=ghcr.io/your-name/my-resume/admin

# 可选：基础镜像覆盖（强烈建议改成你自己的私有仓库，避免 DockerHub token 网络波动）
# DEPLOY_BASE_IMAGE=crpi-xxxx.cn-<region>.personal.cr.aliyuncs.com/<namespace>/my-resume-base-node:22-slim

# 可选：apt 源覆盖（如不配置，默认使用 Debian 官方源）
# DEPLOY_APT_DEBIAN_MIRROR_URL=http://mirrors.aliyun.com/debian
# DEPLOY_APT_SECURITY_MIRROR_URL=http://mirrors.aliyun.com/debian-security

# 镜像 tag（不填则默认使用 release.sh 传入的 tag，如 v2.1.0）
# IMAGE_TAG=v2.1.0

# 可选：让 release.sh 自动执行 docker login（不填则默认你已手动登录）
# REGISTRY_HOST=ghcr.io
# REGISTRY_USERNAME=your-gh-username
# REGISTRY_PASSWORD=ghp_xxx_or_fine_grained_token

# 主域名 / 子域名
ROOT_DOMAIN=example.com
RESUME_DOMAIN=resume.example.com
ADMIN_DOMAIN=admin-resume.example.com
API_DOMAIN=api-resume.example.com

# Let's Encrypt
LETSENCRYPT_EMAIL=ops@example.com

# 鉴权
JWT_SECRET=replace-with-a-long-random-secret

# 证书名称（默认等于 RESUME_DOMAIN，可按需覆盖）
# CERTBOT_CERT_NAME=resume.example.com
# 证书密钥类型（已有 ECDSA 证书时保持 ecdsa，避免 Certbot 误判为切换 RSA）
CERTBOT_KEY_TYPE=ecdsa
# ACME challenge webroot。不要放在 /root 下，否则 nginx 用户可能无法读取。
CERTBOT_WEBROOT=/var/www/my-resume-certbot

# AI Provider
AI_PROVIDER=qiniu
QINIU_AI_API_KEY=replace-with-your-own-key
QINIU_AI_BASE_URL=https://api.qnaigc.com/v1
QINIU_AI_MODEL=deepseek-v3
# QINIU_AI_CHAT_MODEL=deepseek-v3
# QINIU_AI_EMBEDDING_MODEL=text-embedding-v4

# 其他 Provider 预留（按需填写）
# DEEPSEEK_API_KEY=replace-with-your-own-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat
# OPENAI_COMPATIBLE_API_KEY=replace-with-your-own-key
# OPENAI_COMPATIBLE_BASE_URL=https://your-provider.example.com/v1
# OPENAI_COMPATIBLE_MODEL=your-model
