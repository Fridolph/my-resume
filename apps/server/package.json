{
  "name": "@my-resume/server",
  "version": "0.0.1",
  "description": "Personal resume monorepo server scaffold",
  "author": "Fridolph",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "db:check": "ts-node -P tsconfig.json src/database/check-database.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push --force",
    "db:studio": "drizzle-kit studio",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "test": "vitest run --config ./vitest.config.mts",
    "test:watch": "vitest --config ./vitest.config.mts",
    "test:cov": "vitest run --coverage --config ./vitest.config.mts",
    "test:debug": "vitest --inspect-brk --config ./vitest.config.mts --run",
    "test:e2e": "vitest run --config ./vitest.e2e.config.mts"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.0.1",
    "docx": "^9.6.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.18.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.7",
    "@types/pdfkit": "^0.17.5",
    "@types/supertest": "^6.0.2",
    "drizzle-kit": "^0.31.10",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^3.2.4"
  }
}
